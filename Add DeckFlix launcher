def scan_videos(path):
    if not path.exists():
        return []
    return [p for p in path.rglob("*") if p.is_file() and p.suffix.lower() in VIDEO_EXTS]

def size_gb(path):
    try:
        return path.stat().st_size / 1024**3
    except Exception:
        return 0

def quality_score(path):
    n = str(path).lower()
    score = 0
    if "2160p" in n or "4k" in n:
        score += 60
    elif "1080p" in n:
        score += 40
    elif "720p" in n:
        score += 20
    if "bluray" in n:
        score += 25
    elif "web-dl" in n:
        score += 20
    elif "webrip" in n:
        score += 15
    if "repack" in n or "proper" in n:
        score += 5
    if "sample" in n:
        score -= 50
    score += min(int(size_gb(path)), 20)
    return score

def clean_title(name):
    name = name.lower()
    name = re.sub(r"\[[^\]]*\]", " ", name)
    name = re.sub(r"\([^\)]*\)", " ", name)
    name = re.sub(r"\b(720p|1080p|2160p|4k|webrip|web-dl|bluray|brrip|hdrip|dvdscr|x264|x265|yts|tgx|rarbg|galaxyrg|repack|proper|5.1|10bit)\b", " ", name)
    name = re.sub(r"[^a-z0-9]+", " ", name)
    name = re.sub(r"\b(19|20)\d{2}\b", " ", name)
    return " ".join(name.split()).strip()

