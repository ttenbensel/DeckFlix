def get_repair_data():
    movies = scan_videos(MOVIES)
    groups = defaultdict(list)
    junk = []
    nested = []

    for f in movies:
        key = clean_title(f.parent.name)
        if key:
            groups[key].append(f)

        lower = str(f).lower()

        if "sample" in lower or "desktop.ini" in lower or "thumbs.db" in lower:
            junk.append(f)

        try:
            rel = f.resolve().relative_to(MOVIES.resolve())
            if len(rel.parts) >= 3:
                nested.append(f)
        except Exception:
            pass

    duplicates = {k: v for k, v in groups.items() if len(v) > 1}
    return movies, duplicates, junk, nested

def library_health():
    movies, duplicates, junk, nested = get_repair_data()
    tv = scan_videos(TV)

    print()
